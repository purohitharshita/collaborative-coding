# Port the Express + Socket.IO server listens on
PORT=5000

# Comma-separated list of allowed frontend origins (CORS).
# Local dev only: http://localhost:5173
# Production:     http://localhost:5173,https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string.
# Get yours from Atlas → cluster → Connect → Drivers → Node.js.
# URL-encode any special characters (@ : / ? #) in your password.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/collab?appName=YOUR_APP_NAME

# JDoodle compiler API credentials.
# Get from https://www.jdoodle.com/compiler-api → API Credentials tab.
# Free tier: 200 executions/day per clientId.
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=

